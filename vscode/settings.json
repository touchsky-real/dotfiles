{
    "[python]": {
        "editor.formatOnType": true,
        "diffEditor.ignoreTrimWhitespace": true,
    },
    "files.autoSave": "afterDelay",
    "security.workspace.trust.untrustedFiles": "open",
    "terminal.integrated.fontSize": 15,
    "workbench.colorCustomizations": {
        "editor.lineHighlightBackground": "#00000090",
        "editor.lineHighlightBorder": "#ffffff30",
    },
    "editor.formatOnPaste": true,
    "prettier.tabWidth": 4,
    "files.trimTrailingWhitespace": true,
    "window.openFilesInNewWindow": "on",
    "window.openFoldersInNewWindow": "on",
    "editor.unicodeHighlight.nonBasicASCII": false,
    "workbench.startupEditor": "none",
    "[plaintext]": {
        "editor.unicodeHighlight.ambiguousCharacters": false,
        "editor.unicodeHighlight.invisibleCharacters": false,
    },
    "files.autoGuessEncoding": true,
    "editor.wordWrap": "on",
    "editor.renderWhitespace": "boundary",
    "python.REPL.enableREPLSmartSend": false,
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
        "*.xlsx": "default",
        "*.md": "default",
    },
    "window.customTitleBarVisibility": "windowed",
    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "[css]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "remote.SSH.remotePlatform": {
        "*.gitpod.io": "linux",
        "hwserver": "linux",
    },
    "C_Cpp.clang_format_fallbackStyle": "{ BasedOnStyle: Microsoft, BreakBeforeBraces: Attach }",
    "[markdown]": {
        "editor.unicodeHighlight.ambiguousCharacters": false,
        "editor.unicodeHighlight.invisibleCharacters": false,
        "diffEditor.ignoreTrimWhitespace": false,
        "editor.wordWrap": "on",
        "editor.quickSuggestions": {
            "comments": "off",
            "strings": "off",
            "other": "off",
        },
    },
    "workbench.iconTheme": "vscode-icons",
    "terminal.integrated.commandsToSkipShell": ["matlab.interrupt"],
    "python.defaultInterpreterPath": "D:\\develop\\Scoop\\apps\\python312\\3.12.10\\python.exe",
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features",
    },
    "workbench.editor.empty.hint": "hidden",
    "files.associations": {
        "*.py": "python",
    },
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "gitlens.views.scm.grouped.views": {
        "commits": false,
        "branches": false,
        "remotes": false,
        "stashes": false,
        "tags": false,
        "worktrees": false,
        "contributors": false,
        "repositories": false,
        "searchAndCompare": false,
        "launchpad": false,
    },
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": false,
        "scminput": false,
    },
    "launch": {
        "configurations": [],
    },
    "explorer.confirmDelete": false,
    "python.analysis.typeCheckingMode": "basic",
    "intellicode.features.python.showCodeExamples": true,
    "python.languageServer": "Pylance",
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "window.newWindowDimensions": "maximized",
    "git.openRepositoryInParentFolders": "always",
    //code runner配置
    // 关键：解决无法输入的问题，改在终端运行
    //"code-runner.runInTerminal": true,

    // 运行前自动保存文件，防止运行旧代码
    "code-runner.saveFileBeforeRun": true,

    // 运行前清除上一次的输出，保持界面整洁
    "code-runner.clearPreviousOutput": true,

    // 针对特定语言自定义命令 (举例)
    "code-runner.executorMap": {
        // 让 Python 运行当前文件，而不是全局 python
        "python": "$pythonPath -u $fullFileName",
        // 编译 C++ 时支持 C++17 标准并解决中文乱码(Windows下)
        "cpp": "cd $dir && g++ $fileName -o $fileNameWithoutExt -std=c++17 && $dir$fileNameWithoutExt",
    },
    "github.copilot.nextEditSuggestions.enabled": true,
    "claudeCode.preferredLocation": "panel",
    "specstory.cloudSync.enabled": "never",
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "terminal.integrated.fontFamily": "CaskaydiaCove Nerd Font",
    "terminal.integrated.fontLigatures.enabled": true,
    "editor.unicodeHighlight.ambiguousCharacters": false,
    // 开启系统剪贴板同步（强烈推荐：这样在 VS Code 里用 y 复制的内容，可以直接粘贴到浏览器或其他软件中）
  "vim.useSystemClipboard": true,

  // 高亮搜索结果 (使用 / 搜索时)
  "vim.hlsearch": true,

  // 快捷键映射：双击 j 快速退出插入模式 (代替按 Esc 键，手不需要离开主键盘区)
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "j"],
      "after": ["<Esc>"]
    }
  ],

  // 解决快捷键冲突：将部分控制权交还给 VS Code
  "vim.handleKeys": {
    "<C-c>": false, // 允许按 Ctrl+C 进行常规复制
    "<C-v>": false, // 允许按 Ctrl+V 进行常规粘贴
    "<C-f>": false, // 允许按 Ctrl+F 唤起 VS Code 自带的搜索框，而不是 Vim 的翻页
    "<C-a>": false  // 允许按 Ctrl+A 全选
},
"explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
    "*.sqlite": "${capture}.${extname}-*",
    "*.db": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.s3db": "${capture}.${extname}-*"
}
}